<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="false"
    android:descendantFocusability="afterDescendants">

    <!-- ExoPlayer Video Surface -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/video_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        app:use_controller="false"
        app:surface_type="surface_view" />

    <!-- Título Flotante (arriba centro) -->
    <TextView
        android:id="@+id/tv_video_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="32dp"
        android:paddingHorizontal="24dp"
        android:paddingVertical="10dp"
        android:background="#88000000"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:shadowColor="#000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="8"
        android:alpha="0"
        android:visibility="gone"
        android:elevation="10dp"
        android:translationZ="10dp"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- ═══ Controles centrales (play/pause, skip, rewind/forward) ═══ -->
    <LinearLayout
        android:id="@+id/center_controls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <!-- Capítulo anterior -->
        <ImageButton
            android:id="@+id/btn_prev"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            android:scaleType="fitCenter"
            android:padding="10dp"
            android:contentDescription="Previous"
            android:focusable="true"
            android:visibility="gone" />

        <!-- Retroceder 10s -->
        <ImageButton
            android:id="@+id/btn_rewind"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="20dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_rew"
            android:scaleType="fitCenter"
            android:padding="8dp"
            android:contentDescription="Rewind 10s"
            android:focusable="true"
            android:nextFocusDown="@+id/seek_bar" />

        <!-- Play / Pause (grande, protagonista) -->
        <ImageButton
            android:id="@+id/btn_play_pause"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_pause"
            android:scaleType="fitCenter"
            android:padding="12dp"
            android:contentDescription="Play/Pause"
            android:focusable="true"
            android:nextFocusDown="@+id/seek_bar" />

        <!-- Avanzar 10s -->
        <ImageButton
            android:id="@+id/btn_forward"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="20dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_ff"
            android:scaleType="fitCenter"
            android:padding="8dp"
            android:contentDescription="Forward 10s"
            android:focusable="true"
            android:nextFocusDown="@+id/seek_bar" />

        <!-- Capítulo siguiente -->
        <ImageButton
            android:id="@+id/btn_next"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_next"
            android:scaleType="fitCenter"
            android:padding="10dp"
            android:contentDescription="Next"
            android:focusable="true"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ═══ Barra inferior (seekbar + tiempo + botones derecha) ═══ -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#CC000000"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:visibility="gone">

        <!-- SeekBar -->
        <SeekBar
            android:id="@+id/seek_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:progressTint="#7c3aed"
            android:thumbTint="#7c3aed"
            android:maxHeight="3dp"
            android:focusable="true"
            android:nextFocusDown="@+id/btn_tracks"
            android:nextFocusUp="@+id/btn_play_pause" />

        <!-- Fila: Tiempo izq | espacio | botones derecha | tiempo der -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Tiempo actual -->
            <TextView
                android:id="@+id/tv_time_current"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#BBBBBB"
                android:textSize="13sp"
                android:text="00:00" />

            <!-- Espacio flexible -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Pistas (Audio / Subtítulos) -->
            <ImageButton
                android:id="@+id/btn_tracks"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_subtitles"
                android:scaleType="fitCenter"
                android:padding="8dp"
                android:contentDescription="Tracks"
                android:focusable="true"
                android:nextFocusRight="@+id/btn_resize"
                android:nextFocusUp="@+id/seek_bar" />

            <!-- Pantalla completa -->
            <ImageButton
                android:id="@+id/btn_resize"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_fullscreen"
                android:scaleType="fitCenter"
                android:padding="8dp"
                android:contentDescription="Fullscreen"
                android:focusable="true"
                android:nextFocusLeft="@+id/btn_tracks"
                android:nextFocusUp="@+id/seek_bar" />

            <!-- Duración -->
            <TextView
                android:id="@+id/tv_time_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#BBBBBB"
                android:textSize="13sp"
                android:text="00:00" />
        </LinearLayout>
    </LinearLayout>

    <!-- Contenedor Chromecast (añadido para Cineflix) -->
    <FrameLayout
        android:id="@+id/cast_button_container"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="32dp"
        android:visibility="gone" />

    <!-- Botón de Saltar Intro (Aparece durante intro/recap) -->
    <LinearLayout
        android:id="@+id/layout_skip_intro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="90dp"
        android:background="@drawable/bg_next_episode"
        android:orientation="horizontal"
        android:padding="16dp"
        android:focusable="true"
        android:clickable="true"
        android:visibility="gone"
        android:elevation="10dp"
        android:translationZ="10dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:src="@android:drawable/ic_media_ff"
            android:contentDescription="Skip Intro"
            app:tint="#FFFFFF" />

        <TextView
            android:id="@+id/tv_skip_intro_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_gravity="center_vertical"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:text="Saltar Intro" />
    </LinearLayout>

    <!-- Botón de Siguiente Episodio (Aparece al final) -->
    <LinearLayout
        android:id="@+id/layout_next_episode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="90dp"
        android:background="@drawable/bg_next_episode"
        android:orientation="horizontal"
        android:padding="16dp"
        android:focusable="true"
        android:clickable="true"
        android:visibility="gone"
        android:elevation="10dp"
        android:translationZ="10dp">
        
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:src="@android:drawable/ic_media_next"
            android:contentDescription="Next"
            app:tint="#FFFFFF" />
            
        <TextView
            android:id="@+id/tv_next_episode_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_gravity="center_vertical"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:text="Siguiente Episodio" />
    </LinearLayout>

    <!-- Loading spinner -->
    <ProgressBar
        android:id="@+id/loading_spinner"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:indeterminateTint="#7c3aed"
        android:visibility="visible" />

</FrameLayout>
