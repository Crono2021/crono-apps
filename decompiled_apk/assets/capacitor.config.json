{
	"appId": "com.cineflix.android",
	"appName": "Cineflix",
	"webDir": "www",
	"server": {
		"cleartext": true
	},
	"android": {
		"allowMixedContent": true,
		"captureInput": true,
		"webContentsDebuggingEnabled": true
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 1500,
			"backgroundColor": "#0f0f14",
			"showSpinner": false
		}
	}
}
